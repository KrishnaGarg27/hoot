# Server-only ElevenLabs API key.
ELEVENLABS_API_KEY=

# Speech Engine ID returned by `pnpm run speech-engine:create`.
ELEVENLABS_SPEECH_ENGINE_ID=

# Server-only OpenAI API key for Hoot's brain.
OPENAI_API_KEY=

# Optional override (defaults to gpt-4o-mini for low-latency kid Q&A).
# OPENAI_MODEL=gpt-4o-mini

# Optional override for the story-plan generator. Story quality benefits
# from a smarter model; defaults to gpt-4o.
# OPENAI_STORY_PLAN_MODEL=gpt-4o

# Public WebSocket URL, usually from ngrok, including `/ws`.
# Example: wss://your-subdomain.ngrok.app/ws
PUBLIC_WS_URL=

# Optional — the narrator's voice. Any voice from your ElevenLabs library.
# Leave blank to use the engine's default voice. Re-run
# `pnpm run speech-engine:create` after changing this to apply.
# Examples (default ElevenLabs voices):
#   Bella:   EXAVITQu4vr4xnSDxMaL  (soft, young female — good for stories)
#   Lily:    pFZP5JQG7iQjIQuC4Bku  (warm female, child-friendly)
#   Charlie: IKne3meq5aSn9XLyUdCD  (warm male, story-friendly)
#   Rachel:  21m00Tcm4TlvDq8ikWAM  (calm female)
HOOT_VOICE_ID=

# Optional — the TTS model. eleven_multilingual_v2 (default) speaks ~29
# languages with one voice. Use eleven_flash_v2_5 for faster latency
# (also multilingual). Re-run speech-engine:create after changing.
# HOOT_TTS_MODEL_ID=eleven_multilingual_v2
